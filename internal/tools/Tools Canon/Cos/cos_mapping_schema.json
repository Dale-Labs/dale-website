{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kadana.org/schemas/cos-mapping-tool/v1.0.0",
  "title": "CoS Mapping Tool — Canonical Schema",
  "description": "Community Operating System (CoS) Mapping Tool canonical schema. This is the Diagnostic/Sensor layer of the DALE architecture. It captures system signal from a submitted observation package and feeds the ECOA observation pipeline.",
  "version": "1.0.0",
  "tool_id": "CoS",
  "dale_stage": "Observe",
  "architectural_position": {
    "layer": "Tool Interface",
    "role": "Diagnostic/Sensor",
    "feeds_into": "ECOA Observation → ARA Resolution → Runner Execution",
    "canonical_rule": "Tools operate on structure, they do not create it"
  },

  "observation_unit": {
    "description": "One execution of the CoS Mapping Tool on one submitted package of abstract inputs under one concrete observation condition constitutes one observation.",
    "components": {
      "submitted_package": {
        "type": "array",
        "items": { "$ref": "#/definitions/AbstractInput" },
        "minItems": 1,
        "description": "Finite family of candidate abstract inputs submitted for one observation run."
      },
      "observation_condition": { "$ref": "#/definitions/ObservationCondition" },
      "observation_id": {
        "type": "string",
        "description": "Unique identifier for this observation instance.",
        "pattern": "^CoS-[0-9]{4}-[0-9]{2}-[0-9]{2}-[A-Z0-9]{6}$"
      },
      "timestamp": { "type": "string", "format": "date-time" },
      "practitioner_id": { "type": "string" }
    },
    "required": ["submitted_package", "observation_condition", "observation_id", "timestamp"]
  },

  "definitions": {

    "AbstractInput": {
      "type": "object",
      "description": "One admissible abstract input unit. Must be expressible as a system under the fixed DALE principle-model frame. Every active internal unit must be realizable as an operational or fundamental variable.",
      "properties": {
        "input_id": { "type": "string" },
        "input_label": { "type": "string", "description": "Short descriptive label for this input unit." },
        "input_text": { "type": "string", "description": "The raw abstract input content as submitted." },
        "admissibility_status": {
          "type": "string",
          "enum": ["admissible", "form_noise", "decomposition_noise", "architectural_noise"],
          "description": "Whether this input unit passed admissibility check. Non-admissible inputs are recorded but do not enter the observational process."
        },
        "operational_scope": {
          "type": "array",
          "items": { "$ref": "#/definitions/OperationalVariableRef" },
          "description": "Set of operational variables through which this input is first admissibly realized."
        }
      },
      "required": ["input_id", "input_text", "admissibility_status"]
    },

    "ObservationCondition": {
      "type": "object",
      "description": "Concrete observation condition under which the submitted package is processed. Conditions activate and restrict the observational path without redefining the architecture.",
      "properties": {
        "condition_id": { "type": "string" },
        "sector": { "type": "string", "description": "e.g. climate finance, health, education, livelihoods" },
        "geography": { "type": "string" },
        "engagement_type": {
          "type": "string",
          "enum": ["Level1_ClientProject", "Level2_CommunitySprint", "Level3_Platform"]
        },
        "observation_mode": {
          "type": "string",
          "enum": ["facilitated_session", "document_review", "interview_series", "mixed"]
        },
        "date": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      },
      "required": ["condition_id", "engagement_type", "observation_mode"]
    },

    "FundamentalVariable": {
      "type": "object",
      "description": "One of the 40 canonical fundamental variables forming the common empirical layer of the DALE-ECOA architecture.",
      "properties": {
        "variable_id": { "type": "string", "pattern": "^v[1-9]|v[1-3][0-9]|v40$" },
        "variable_name": {
          "type": "string",
          "enum": [
            "identity", "dignity", "agency", "psychological_safety",
            "participant_readiness", "participant_overload", "participant_freeze",
            "reflective_capacity", "adaptive_thinking", "pattern_noticing", "cognitive_load",
            "beneficiary_position", "customer_position", "payer_position",
            "payment_capacity", "decision_authority",
            "community_participation", "community_stewardship",
            "system_structure", "decision_pathway", "power_asymmetry", "invisible_influence",
            "localization", "local_actor_agency", "local_actor_autonomy", "contextual_fit",
            "value", "impact", "resourcing",
            "money_flow", "impact_flow", "data_flow", "decision_flow", "flow_coherence",
            "root_cause_depth", "problem_priority", "assumption_exposure", "learning_adaptivity",
            "continuity_risk", "roadmap_readiness"
          ]
        },
        "family": {
          "type": "string",
          "enum": [
            "participant_grounded_formation",
            "relational_actor_position",
            "system_participation_influence",
            "localization_contextual_fit",
            "value_impact_resourcing_flow",
            "problem_change_learning",
            "continuity_execution"
          ]
        },
        "activation_status": {
          "type": "string",
          "enum": ["activated", "not_activated"],
          "description": "Whether this variable is activated in the current observation path."
        },
        "empirical_value": {
          "oneOf": [
            { "type": "number", "minimum": -1, "maximum": 1 },
            { "type": "string", "enum": ["info_absence"] }
          ],
          "description": "Assigned empirical value in [-1, 1] or explicit informational absence. -1 = minimum admissible state. 0 = neutral (no effective contribution). 1 = maximum admissible state."
        },
        "output_status": {
          "type": "string",
          "enum": ["assigned", "info_absence", "struct_absence"],
          "description": "assigned: valid empirical value produced. info_absence: activated but required information missing. struct_absence: admissible but not in activated path."
        },
        "local_signed_state": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "terminal_subsystem_ref": { "type": "string" },
              "signed_state_value": {
                "oneOf": [
                  { "type": "number", "minimum": -1, "maximum": 1 },
                  { "type": "string", "enum": ["info_absence"] }
                ]
              }
            }
          },
          "description": "Local signed states from terminal realized subsystems. Aggregated to produce final empirical value."
        },
        "governing_principles": {
          "type": "array",
          "items": { "$ref": "#/definitions/PrincipleRef" }
        },
        "governing_models": {
          "type": "array",
          "items": { "$ref": "#/definitions/ModelRef" }
        },
        "trace_ref": { "type": "string" }
      },
      "required": ["variable_id", "variable_name", "family", "activation_status", "output_status"]
    },

    "OperationalVariable": {
      "type": "object",
      "description": "One of the 12 canonical operational variables. First readable reconstructed layer above the common fundamental empirical layer.",
      "properties": {
        "variable_id": { "type": "string", "pattern": "^X([1-9]|1[0-2])$" },
        "variable_name": {
          "type": "string",
          "enum": [
            "identity_articulation_state",
            "safety_and_participation_state",
            "system_description_state",
            "flow_visibility_state",
            "position_power_and_influence_state",
            "problem_framing_state",
            "design_direction_state",
            "learning_and_validation_state",
            "audience_and_payment_structure_state",
            "value_impact_enterprise_state",
            "resourcing_scale_and_continuity_state",
            "coordination_localization_and_roadmap_state"
          ]
        },
        "operational_family": {
          "type": "string",
          "enum": ["participant_grounded_formation", "structural_describability", "relational_differentiation", "coordination_closure"]
        },
        "dale_family": {
          "type": "array",
          "items": { "type": "string", "enum": ["Delivery", "Accountability", "Learning", "Ecosystem"] }
        },
        "activation_status": {
          "type": "string",
          "enum": ["activated", "not_activated"]
        },
        "empirical_value": {
          "oneOf": [
            { "type": "number", "minimum": -1, "maximum": 1 },
            { "type": "string", "enum": ["info_absence"] }
          ],
          "description": "Reconstructed operational empirical state. Default: arithmetic mean of assigned contributing fundamental values."
        },
        "output_status": {
          "type": "string",
          "enum": ["assigned", "info_absence", "struct_absence"]
        },
        "contributing_fundamental_variables": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fundamental variable IDs from the fixed admissible base that contributed to this reconstruction."
        },
        "non_activated_base_variables": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fundamental variable IDs in the fixed base that were not activated in this observation."
        },
        "governing_principles": {
          "type": "array",
          "items": { "$ref": "#/definitions/PrincipleRef" }
        },
        "governing_models": {
          "type": "array",
          "items": { "$ref": "#/definitions/ModelRef" }
        },
        "trace_ref": { "type": "string" }
      },
      "required": ["variable_id", "variable_name", "operational_family", "activation_status", "output_status"]
    },

    "OperationalVariableRef": {
      "type": "object",
      "properties": {
        "variable_id": { "type": "string", "pattern": "^X([1-9]|1[0-2])$" },
        "variable_name": { "type": "string" }
      },
      "required": ["variable_id"]
    },

    "PrincipleRef": {
      "type": "object",
      "description": "Reference to one of the 5 fixed global DALE principles.",
      "properties": {
        "principle_id": { "type": "string", "enum": ["P1", "P2", "P3", "P4", "P5"] },
        "principle_name": {
          "type": "string",
          "enum": [
            "Participant-grounded legitimacy",
            "Structural observation before intervention",
            "Explicit relational differentiation for decision-relevant system readability",
            "Context-fit and bounded movement",
            "Adaptive continuity with local agency"
          ]
        }
      },
      "required": ["principle_id"]
    },

    "ModelRef": {
      "type": "object",
      "description": "Reference to an admissible component model from the global DALE model families.",
      "properties": {
        "model_family": { "type": "string", "enum": ["M1", "M2", "M3", "M4", "M5"] },
        "model_name": { "type": "string" }
      },
      "required": ["model_family", "model_name"]
    },

    "DALEFamilyState": {
      "type": "object",
      "description": "Empirical state for one DALE reporting family (Delivery, Accountability, Learning, Ecosystem).",
      "properties": {
        "family": { "type": "string", "enum": ["Delivery", "Accountability", "Learning", "Ecosystem"] },
        "empirical_value": {
          "oneOf": [
            { "type": "number", "minimum": -1, "maximum": 1 },
            { "type": "string", "enum": ["info_absence"] }
          ]
        },
        "signal_status": {
          "type": "string",
          "enum": ["present", "info_absence", "struct_absence"]
        },
        "contributing_operational_variables": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["family", "signal_status"]
    },

    "OutputRecord": {
      "type": "object",
      "description": "Canonical empirical output record. Every output preserves full structural traceability.",
      "properties": {
        "observation_id": { "type": "string" },
        "source_tool": { "type": "string", "const": "CoS" },
        "layer": {
          "type": "string",
          "enum": ["fundamental", "operational", "family", "abstract", "dale_reporting"]
        },
        "family": { "type": "string" },
        "entity_id": { "type": "string" },
        "state_id": { "type": "string" },
        "empirical_value": {
          "oneOf": [
            { "type": "number", "minimum": -1, "maximum": 1 },
            { "type": "string", "enum": ["info_absence"] },
            { "type": "null" }
          ]
        },
        "status": {
          "type": "string",
          "enum": ["assigned", "info_absence", "struct_absence"]
        },
        "used_variables": { "type": "array", "items": { "type": "string" } },
        "inactive_variables": { "type": "array", "items": { "type": "string" } },
        "used_principles": { "type": "array", "items": { "type": "string" } },
        "used_models": { "type": "array", "items": { "type": "string" } },
        "observation_condition": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "trace_ref": { "type": "string" }
      },
      "required": ["observation_id", "source_tool", "layer", "state_id", "status", "observation_condition", "timestamp"]
    }
  },

  "output_structure": {
    "description": "Full layered output produced by one CoS observation run.",
    "properties": {
      "fundamental_empirical_state": {
        "type": "array",
        "items": { "$ref": "#/definitions/FundamentalVariable" },
        "description": "First common empirical output layer. Basis for all higher reconstruction."
      },
      "operational_empirical_state": {
        "type": "array",
        "items": { "$ref": "#/definitions/OperationalVariable" },
        "description": "Reconstructed operational empirical states. First readable output layer."
      },
      "dale_family_states": {
        "type": "array",
        "items": { "$ref": "#/definitions/DALEFamilyState" },
        "description": "DALE-readable reporting layer. Compact empirical configuration across D/A/L/E families."
      },
      "output_records": {
        "type": "array",
        "items": { "$ref": "#/definitions/OutputRecord" },
        "description": "Full canonical output records with traceability for master dataset integration."
      },
      "noise_log": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "input_id": { "type": "string" },
            "noise_type": { "type": "string", "enum": ["form_noise", "decomposition_noise", "architectural_noise"] },
            "reason": { "type": "string" }
          }
        },
        "description": "Non-admissible input units. Recorded for transparency but excluded from empirical output."
      },
      "balance_relevant_missingness": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "terminal_subsystem_ref": { "type": "string" },
            "missing_variables": { "type": "array", "items": { "type": "string" } },
            "status": { "type": "string", "const": "balance_relevant_missingness" }
          }
        },
        "description": "Variables required by governing principles for system balance but absent from terminal realization."
      }
    },
    "required": ["fundamental_empirical_state", "operational_empirical_state", "output_records"]
  },

  "architectural_constraints": {
    "description": "Fixed laws that cannot be modified during observational execution.",
    "fixed_elements": [
      "global_principle_set (P1-P5)",
      "global_model_families (M1-M5)",
      "fundamental_variable_layer (v1-v40)",
      "operational_variable_layer (X1-X12)",
      "role_map (fund/op)",
      "metric_domain ([-1,1])",
      "decomposition_operator",
      "signed_state_operator",
      "metric_assignment_operator",
      "upward_reconstruction_functionals"
    ],
    "revision_space": [
      "fundamental_variable_layer (through later architectural refinement only)",
      "operational_variable_layer (through later architectural refinement only)"
    ],
    "not_permitted_during_execution": [
      "introducing a third variable class",
      "reassigning variable roles",
      "redefining global principles or model families",
      "permitting observationally active content outside the variable architecture",
      "inserting neutral or default values in place of explicit informational absence",
      "collapsing balance_relevant_missingness into info_absence or neutral"
    ]
  },

  "tool_integration_fields": {
    "description": "Fields required for integration with the unified DALE master dataset.",
    "required_fields": [
      "ObservationID", "SourceTool", "Layer", "Family",
      "EntityID", "StateID", "EmpiricalValue", "Status",
      "UsedVariables", "InactiveVariables", "UsedPrinciples", "UsedModels",
      "ObservationCondition", "Timestamp", "TracePath"
    ]
  }
}
